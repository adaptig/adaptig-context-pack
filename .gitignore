# macOS
.DS_Store

# Archive (large binaries: videos, presentation templates)
archive/

# Video files in brand-assets (logo animations, tutorials — too large for git)
brand-assets/**/*.mp4
brand-assets/**/*.mov

# Adobe Illustrator source files
brand-assets/**/*.ai

# Company presentation decks (large binaries, stored in shared Drive instead)
brand-assets/company-presentation/*.pptx
brand-assets/company-presentation/*.pdf
